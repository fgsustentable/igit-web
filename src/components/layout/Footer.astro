---
import { t, localizedHref, type Lang, type RouteKey } from '@/i18n/utils';
import site from '@/data/site.json';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const navKeys: RouteKey[] = ['about', 'news', 'publications', 'projects', 'contact', 'search'];
const navLinks = navKeys.map((key) => ({ href: localizedHref(key, lang), label: t(lang, `nav.${key}`) }));

const year = new Date().getFullYear();
const fullName = t(lang, 'site.fullName');

const social = Object.entries(site.social)
  .filter(([, url]) => typeof url === 'string' && url.length > 0)
  .map(([network, url]) => ({ network, url }));
---

<footer class="mt-24 border-t border-border bg-primary-dark text-white/85">
  <div class="mx-auto max-w-[1200px] px-4 py-14 sm:px-6">
    <div class="grid gap-10 md:grid-cols-[1.4fr_1fr_1fr]">
      <div>
        <div class="flex items-center gap-2.5">
          <svg width="30" height="30" viewBox="0 0 64 64" aria-hidden="true">
            <rect width="64" height="64" rx="14" fill="#0E4F5C"></rect>
            <g fill="none" stroke="#FBFAF7" stroke-opacity="0.6" stroke-width="2.5" stroke-linecap="round">
              <path d="M10 40c8-2 12-9 22-9s15 7 22 5"></path>
              <path d="M14 31c6-2 9-6 18-6s12 4 18 3"></path>
            </g>
            <circle cx="32" cy="23" r="4.5" fill="#E0A458"></circle>
          </svg>
          <span class="font-display text-lg font-bold text-white">IGIT</span>
        </div>
        <p class="mt-4 max-w-sm text-sm leading-relaxed text-white/70">{fullName}</p>
        <p class="mt-2 text-sm font-medium text-accent">{t(lang, 'footer.tagline')}</p>
      </div>

      <nav aria-label={t(lang, 'footer.navTitle')}>
        <h2 class="font-display text-sm font-semibold uppercase tracking-wide text-white/55">
          {t(lang, 'footer.navTitle')}
        </h2>
        <ul class="mt-4 space-y-2.5 text-sm">
          {
            navLinks.map((link) => (
              <li>
                <a href={link.href} class="text-white/80 transition-colors hover:text-accent">
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div>
        <h2 class="font-display text-sm font-semibold uppercase tracking-wide text-white/55">
          {t(lang, 'footer.contactTitle')}
        </h2>
        <ul class="mt-4 space-y-2.5 text-sm">
          <li>
            <a href={`mailto:${site.contactEmail}`} class="text-white/80 transition-colors hover:text-accent">
              {site.contactEmail}
            </a>
          </li>
          {
            social.map((s) => (
              <li>
                <a href={s.url} rel="me noopener" target="_blank" class="capitalize text-white/80 transition-colors hover:text-accent">
                  {s.network}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div class="mt-12 flex flex-col gap-2 border-t border-white/10 pt-6 text-xs text-white/55 sm:flex-row sm:items-center sm:justify-between">
      <p>© {year} {fullName}. {t(lang, 'footer.rights')}</p>
      <p>{t(lang, 'footer.builtWith')}</p>
    </div>
  </div>
</footer>
