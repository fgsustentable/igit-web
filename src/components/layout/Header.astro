---
import { t, localizedHref, localizePath, altLang, type Lang, type RouteKey } from '@/i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.tsx';
import MobileMenu from './MobileMenu.tsx';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const pathname = Astro.url.pathname;

const navKeys: RouteKey[] = ['about', 'news', 'publications', 'projects', 'contact'];

function isCurrent(href: string): boolean {
  const here = pathname.replace(/\/$/, '') || '/';
  const target = href.replace(/\/$/, '') || '/';
  if (target === '/' || target === '/es') return here === target;
  return here === target || here.startsWith(target + '/');
}

const navLinks = navKeys.map((key) => {
  const href = localizedHref(key, lang);
  return { href, label: t(lang, `nav.${key}`), current: isCurrent(href) };
});

const homeHref = localizedHref('home', lang);
const searchHref = localizedHref('search', lang);
const switchHref = localizePath(pathname, altLang(lang));
const switchLabel = lang === 'gl' ? t('gl', 'a11y.switchToEs') : t('es', 'a11y.switchToGl');
---

<header class="sticky top-0 z-40 border-b border-border bg-bg/90 backdrop-blur">
  <div class="mx-auto flex h-16 max-w-[1200px] items-center justify-between gap-4 px-4 sm:px-6">
    <a href={homeHref} class="flex items-center gap-2.5 rounded-btn" aria-label={t(lang, 'a11y.homeLink')}>
      <svg width="32" height="32" viewBox="0 0 64 64" aria-hidden="true" class="shrink-0">
        <rect width="64" height="64" rx="14" fill="#0E4F5C"></rect>
        <g fill="none" stroke="#FBFAF7" stroke-opacity="0.55" stroke-width="2.5" stroke-linecap="round">
          <path d="M10 40c8-2 12-9 22-9s15 7 22 5"></path>
          <path d="M14 31c6-2 9-6 18-6s12 4 18 3"></path>
        </g>
        <circle cx="32" cy="23" r="4.5" fill="#E0A458"></circle>
      </svg>
      <span class="font-display text-xl font-bold tracking-tight text-primary-dark">IGIT</span>
    </a>

    <nav class="hidden items-center gap-1 md:flex" aria-label={t(lang, 'a11y.mainNav')}>
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            aria-current={link.current ? 'page' : undefined}
            class:list={[
              'rounded-btn px-3 py-2 text-sm font-medium transition-colors hover:text-primary',
              link.current ? 'text-primary' : 'text-text',
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <a
        href={searchHref}
        aria-label={t(lang, 'nav.search')}
        class="hidden h-10 w-10 items-center justify-center rounded-btn border border-border text-primary transition-colors hover:bg-primary/5 md:inline-flex"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7"></circle>
          <path d="m20 20-3.5-3.5"></path>
        </svg>
      </a>

      <LanguageSwitcher client:load lang={lang} fallbackHref={switchHref} label={switchLabel} />

      <MobileMenu
        client:load
        links={navLinks}
        openLabel={t(lang, 'a11y.openMenu')}
        closeLabel={t(lang, 'a11y.closeMenu')}
        searchHref={searchHref}
        searchLabel={t(lang, 'nav.search')}
      />
    </div>
  </div>
</header>
