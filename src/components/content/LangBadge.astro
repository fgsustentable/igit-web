---
import { t, type Lang } from '@/i18n/utils';

interface Props {
  /** Idioma do CONTIDO (o que indica a etiqueta). */
  lang: Lang;
  /** Idioma da INTERFACE (para o texto accesible). */
  uiLang: Lang;
  class?: string;
}
const { lang, uiLang, class: className = '' } = Astro.props;

const label = t(uiLang, `langBadge.${lang}`);
const aria = t(uiLang, lang === 'gl' ? 'langBadge.glLabel' : 'langBadge.esLabel');
---

<span
  class:list={[
    'inline-flex items-center rounded-chip border px-1.5 py-0.5 text-[11px] font-semibold uppercase leading-none tracking-wide',
    lang === 'gl'
      ? 'border-primary/30 bg-primary/10 text-primary'
      : 'border-secondary/30 bg-secondary/10 text-secondary',
    className,
  ]}
  title={aria}
>
  <span class="sr-only">{aria}</span>
  <span aria-hidden="true">{label}</span>
</span>
