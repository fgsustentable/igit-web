---
import TopoTexture from '@/components/content/TopoTexture.astro';

/**
 * Cabeceira de páxina (título + intro) co motivo topográfico.
 * Reutilizable en «Que facemos», listaxes e páxinas internas.
 */
interface Props {
  title: string;
  intro?: string;
  /** Texto curto en maiúsculas sobre o título (ex.: o claim). */
  eyebrow?: string;
}
const { title, intro, eyebrow } = Astro.props;
---

<section class="relative overflow-hidden border-b border-border bg-bg">
  <TopoTexture
    class="pointer-events-none absolute inset-0 h-full w-full text-primary"
    opacity={0.08}
  />
  <div class="relative mx-auto max-w-[1200px] px-4 py-14 sm:px-6 sm:py-20">
    {
      eyebrow && (
        <p class="font-display text-sm font-semibold uppercase tracking-[0.18em] text-secondary">
          {eyebrow}
        </p>
      )
    }
    <h1 class="mt-3 max-w-3xl text-[clamp(1.75rem,4vw,3rem)] font-bold leading-[1.1] text-primary-dark">
      {title}
    </h1>
    {intro && <p class="mt-5 max-w-2xl text-lg leading-relaxed text-muted">{intro}</p>}
  </div>
</section>
