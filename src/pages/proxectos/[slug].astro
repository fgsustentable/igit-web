---
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Prose from '@/components/content/Prose.astro';
import LangBadge from '@/components/content/LangBadge.astro';
import Icon from '@/components/content/Icon.astro';
import { t, localizedHref, formatDate } from '@/i18n/utils';

export const getStaticPaths = (async () => {
  const proxectos = await getCollection('proxectos');
  return proxectos.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { Content } = await render(entry);

// A interface do detalle vai no idioma do contido.
const lang = entry.data.lang;
const { title, summary, date, status, externalUrl, cover } = entry.data;

const statusKey = status === 'en-curso' ? 'content.statusEnCurso' : 'content.statusFinalizado';
---

<BaseLayout
  lang={lang}
  title={title}
  description={summary}
  ogType="article"
  ogImage={`/og/proxectos-${entry.id}.png`}
>
  <article class="mx-auto max-w-[720px] px-4 py-12 sm:py-16">
    <a
      href={localizedHref('projects', lang)}
      class="inline-flex items-center gap-1 text-sm font-medium text-primary transition-colors hover:text-primary-dark"
    >
      <span aria-hidden="true">&larr;</span>
      {t(lang, 'content.backToProjects')}
    </a>

    <header class="mt-6">
      <div class="flex flex-wrap items-center gap-2 text-xs text-muted">
        <LangBadge lang={lang} uiLang={lang} />
        <span
          class:list={[
            'inline-flex items-center rounded-chip px-1.5 py-0.5 font-medium leading-none',
            status === 'en-curso' ? 'bg-secondary/10 text-secondary' : 'bg-muted/15 text-muted',
          ]}
        >
          {t(lang, statusKey)}
        </span>
        {date && <time datetime={date.toISOString()} class="tabular-nums">{formatDate(date, lang)}</time>}
      </div>
      <h1 class="mt-3 text-[clamp(1.75rem,4vw,2.75rem)] font-bold leading-[1.1] text-primary-dark">
        {title}
      </h1>
      <p class="mt-4 text-lg leading-relaxed text-muted">{summary}</p>

      {
        externalUrl && (
          <a
            href={externalUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-6 inline-flex items-center gap-2 rounded-btn bg-primary px-5 py-2.5 font-medium text-white transition-colors hover:bg-primary-dark"
          >
            <Icon name="external-link" size={18} />
            {t(lang, 'content.visit')}
          </a>
        )
      }
    </header>

    {
      cover && (
        <img
          src={cover}
          alt=""
          class="mt-8 w-full rounded-card border border-border"
          loading="lazy"
          decoding="async"
        />
      )
    }

    <Prose class="mt-8">
      <Content />
    </Prose>
  </article>
</BaseLayout>
