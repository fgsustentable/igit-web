---
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Prose from '@/components/content/Prose.astro';
import LangBadge from '@/components/content/LangBadge.astro';
import Icon from '@/components/content/Icon.astro';
import { t, localizedHref, formatDate } from '@/i18n/utils';

export const getStaticPaths = (async () => {
  const publicacions = await getCollection('publicacions');
  return publicacions.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { Content } = await render(entry);

// A interface do detalle vai no idioma do contido.
const lang = entry.data.lang;
const { title, summary, date, authors, pdf, tags, cover } = entry.data;
---

<BaseLayout
  lang={lang}
  title={title}
  description={summary}
  ogType="article"
  ogImage={`/og/publicacions-${entry.id}.png`}
>
  <article class="mx-auto max-w-[720px] px-4 py-12 sm:py-16">
    <a
      href={localizedHref('publications', lang)}
      class="inline-flex items-center gap-1 text-sm font-medium text-primary transition-colors hover:text-primary-dark"
    >
      <span aria-hidden="true">&larr;</span>
      {t(lang, 'content.backToPublications')}
    </a>

    <header class="mt-6">
      <div class="flex flex-wrap items-center gap-2 text-xs text-muted">
        <LangBadge lang={lang} uiLang={lang} />
        <time datetime={date.toISOString()} class="tabular-nums">{formatDate(date, lang)}</time>
      </div>
      <h1 class="mt-3 text-[clamp(1.75rem,4vw,2.75rem)] font-bold leading-[1.1] text-primary-dark">
        {title}
      </h1>
      <p class="mt-4 text-lg leading-relaxed text-muted">{summary}</p>

      {
        authors && (
          <p class="mt-3 text-sm text-muted">
            <span class="font-medium text-text">{t(lang, 'content.authors')}:</span> {authors}
          </p>
        )
      }

      {
        pdf && (
          <a
            href={pdf}
            download
            class="mt-6 inline-flex items-center gap-2 rounded-btn bg-primary px-5 py-2.5 font-medium text-white transition-colors hover:bg-primary-dark"
          >
            <Icon name="download" size={18} />
            {t(lang, 'content.downloadPdf')}
          </a>
        )
      }
    </header>

    {
      cover && (
        <img
          src={cover}
          alt=""
          class="mt-8 w-full rounded-card border border-border"
          loading="lazy"
          decoding="async"
        />
      )
    }

    <Prose class="mt-8">
      <Content />
    </Prose>

    {
      tags.length > 0 && (
        <ul class="mt-10 flex flex-wrap gap-1.5 border-t border-border pt-6">
          <li class="sr-only">{t(lang, 'content.tags')}</li>
          {tags.map((tag) => (
            <li class="rounded-chip bg-bg px-2 py-0.5 text-xs font-medium text-muted ring-1 ring-border">
              {tag}
            </li>
          ))}
        </ul>
      )
    }
  </article>
</BaseLayout>
