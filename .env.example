# --- IGIT Web — variables de contorno ---
# Copia este ficheiro a .env e enche os valores. NUNCA commitees .env.

# URL canónica do sitio (sen barra final)
PUBLIC_SITE_URL="https://igit.gal"

# Access key do formulario de contacto (web3forms.com)
PUBLIC_WEB3FORMS_KEY=""

# --- Keystatic en modo GitHub (só produción) ---
# En desenvolvemento Keystatic usa modo `local` e NON precisa estas variables.
# GitHub → Settings → Developer settings → OAuth Apps
KEYSTATIC_GITHUB_CLIENT_ID=""
KEYSTATIC_GITHUB_CLIENT_SECRET=""
# Cadea aleatoria para asinar a sesión: openssl rand -hex 32
KEYSTATIC_SECRET=""
